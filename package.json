{
  "name": "asmr-trans",
  "version": "0.3.1",
  "private": true,
  "description": "Local desktop audio transcription for Japanese and Chinese audio.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder --win nsis",
    "pack": "npm run build && electron-builder --win dir",
    "preview": "vite preview --host 127.0.0.1",
    "electron": "electron .",
    "verify": "node scripts/verify.cjs",
    "test:electron-smoke": "npm run build && node scripts/check-electron-smoke.cjs",
    "test:export-store": "node scripts/check-export-store.cjs",
    "test:export": "node scripts/check-export-utils.cjs",
    "test:history": "node scripts/check-history-store.cjs",
    "test:history-ui": "node scripts/check-history-utils.cjs",
    "test:logic": "npm run test:export && npm run test:export-store && npm run test:history && npm run test:history-ui && npm run test:queue && npm run test:readiness && npm run test:segment-list && npm run test:segments && npm run test:settings && npm run test:text && npm run test:translation-retry",
    "test:python-worker": "node scripts/check-python-worker-smoke.cjs",
    "test:queue": "node scripts/check-queue-utils.cjs",
    "test:real-whisper": "node scripts/check-real-whisper-smoke.cjs",
    "test:readiness": "node scripts/check-readiness-utils.cjs",
    "test:segment-list": "node scripts/check-segment-list-utils.cjs",
    "test:segments": "node scripts/check-segment-edit-utils.cjs",
    "test:settings": "node scripts/check-settings-store.cjs",
    "test:text": "node scripts/check-text-integrity.cjs",
    "test:translation-retry": "node scripts/check-translation-retry-utils.cjs",
    "python:check": "py -3 python/worker.py --check"
  },
  "build": {
    "appId": "local.asmr-trans.desktop",
    "productName": "ASMR Trans",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "runtime/python",
        "to": "runtime/python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ASMR Trans"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
